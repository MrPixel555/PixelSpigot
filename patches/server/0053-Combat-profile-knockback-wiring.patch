-                            com.hpfxd.pandaspigot.config.PandaSpigotWorldConfig.KnockbackConfig knockbackConfig = entity.world.pandaSpigotConfig.knockback;
-                            entity.g(
-                                    -MathHelper.sin(this.yaw * 3.1415927F / 180.0F) * (float) i * knockbackConfig.extraHorizontal,
-                                    knockbackConfig.extraVertical,
-                                    MathHelper.cos(this.yaw * 3.1415927F / 180.0F) * (float) i * knockbackConfig.extraHorizontal);
-                            // PandaSpigot end
-                            this.motX *= 0.6D;
-                            this.motZ *= 0.6D;
-                            this.setSprinting(false);
+                            // PandaSpigot start - Combat profile knockback
+                            com.hpfxd.pandaspigot.knockback.KnockbackConfig.applyExtraKnockback(entity, this, i);
+                            // PandaSpigot end
                         }
+
+                        // PandaSpigot start - Combat profile attacker slowdown/sprint reset
+                        com.hpfxd.pandaspigot.knockback.KnockbackConfig.applyAttackerPostHit(this);
+                        // PandaSpigot end
 
                         if (f > 0.0F) {
                             this.b(entity);
