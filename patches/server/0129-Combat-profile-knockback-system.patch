+        settings.horizontalOffsetEnabled = yaml.getBoolean(root + "HORIZONTAL-OFFSET-ENABLED", settings.horizontalOffsetEnabled);
+        settings.horizontalOffset = yaml.getDouble(root + "HORIZONTAL-OFFSET", settings.horizontalOffset);
+        settings.hitboxSize = yaml.getDouble(root + "HITBOX-SIZE", settings.hitboxSize);
+        settings.trajectoryRandomness = yaml.getDouble(root + "TRAJECTORY-RANDOMNESS", settings.trajectoryRandomness);
+        settings.selfCollisionTicks = yaml.getInt(root + "SELF-COLLISION-TICKS", settings.selfCollisionTicks);
+        settings.copyTargetYPosition = yaml.getBoolean(root + "COPY-TARGET-Y-POSITION", settings.copyTargetYPosition);
+        settings.smoothPotion = yaml.getBoolean(root + "SMOOTH-POTION", settings.smoothPotion);
+    }
+
+    private static void validate(Profile loaded) throws InvalidConfigurationException {
+        validateKnockback("KNOCKBACK", loaded.knockback);
+        validateImpact("IMPACT.ENDER-PEARL", loaded.enderPearlImpact);
+        validateImpact("IMPACT.SNOWBALL", loaded.snowballImpact);
+        validateImpact("IMPACT.EGG", loaded.eggImpact);
+        validateImpact("IMPACT.FISHING-HOOK", loaded.fishingHookImpact);
+        validateImpact("IMPACT.ARROW", loaded.arrowImpact);
+        validateImpact("IMPACT.EXPLOSION", loaded.explosionImpact);
+        validateProjectile("PROJECTILE.ENDER-PEARL", loaded.enderPearlProjectile);
+        validateProjectile("PROJECTILE.SNOWBALL", loaded.snowballProjectile);
+        validateProjectile("PROJECTILE.EGG", loaded.eggProjectile);
+        validateProjectile("PROJECTILE.FISHING-HOOK", loaded.fishingHookProjectile);
+        validateProjectile("PROJECTILE.ARROW", loaded.arrowProjectile);
+        validateProjectile("PROJECTILE.SPLASH-POTION", loaded.splashPotionProjectile);
+    }
+
+    private static void validateKnockback(String path, KnockbackSettings settings) throws InvalidConfigurationException {
+        finite(path + ".HORIZONTAL", settings.horizontal);
+        finite(path + ".VERTICAL", settings.vertical);
+        finite(path + ".VERTICAL-LIMIT", settings.verticalLimit);
+        positive(path + ".HORIZONTAL-FRICTION", settings.horizontalFriction);
+        positive(path + ".VERTICAL-FRICTION", settings.verticalFriction);
+        finite(path + ".EXTRA-HORIZONTAL", settings.extraHorizontal);
+        finite(path + ".EXTRA-VERTICAL", settings.extraVertical);
+        finite(path + ".SLOWDOWN.VALUE", settings.slowdown.value);
+        nonNegative(path + ".MAX-NO-DAMAGE-TICKS.VALUE", settings.maxNoDamageTicks.value);
+    }
+
+    private static void validateImpact(String path, ImpactSettings settings) throws InvalidConfigurationException {
+        finite(path + ".HORIZONTAL", settings.horizontal);
+        finite(path + ".VERTICAL", settings.vertical);
+        positive(path + ".HORIZONTAL-FRICTION", settings.horizontalFriction);
+        positive(path + ".VERTICAL-FRICTION", settings.verticalFriction);
+        finite(path + ".VERTICAL-LIMIT", settings.verticalLimit);
+        finite(path + ".MIN-VERTICAL-LIMIT", settings.minVerticalLimit);
+        nonNegative(path + ".MAX-NO-DAMAGE-TICKS.VALUE", settings.maxNoDamageTicks.value);
+    }
+
+    private static void validateProjectile(String path, ProjectileSettings settings) throws InvalidConfigurationException {
+        finite(path + ".LAUNCH-SPEED", settings.launchSpeed);
+        finite(path + ".SPEED-MULTIPLIER", settings.speedMultiplier);
+        finite(path + ".GRAVITY", settings.gravity);
+        finite(path + ".VERTICAL-OFFSET", settings.verticalOffset);
+        finite(path + ".HORIZONTAL-OFFSET", settings.horizontalOffset);
+        nonNegative(path + ".HITBOX-SIZE", settings.hitboxSize);
+        nonNegative(path + ".TRAJECTORY-RANDOMNESS", settings.trajectoryRandomness);
+        nonNegative(path + ".SELF-COLLISION-TICKS", settings.selfCollisionTicks);
+    }
+
+    private static void finite(String path, double value) throws InvalidConfigurationException {
+        if (Double.isNaN(value) || Double.isInfinite(value)) {
+            throw new InvalidConfigurationException(path + " must be a finite number");
+        }
+    }
+
+    private static void positive(String path, double value) throws InvalidConfigurationException {
+        finite(path, value);
+        if (value <= 0.0D) {
+            throw new InvalidConfigurationException(path + " must be greater than zero");
+        }
+    }
+
+    private static void nonNegative(String path, double value) throws InvalidConfigurationException {
+        finite(path, value);
+        if (value < 0.0D) {
+            throw new InvalidConfigurationException(path + " must not be negative");
+        }
+    }
+
+    public static void applyKnockback(EntityLiving victim, Entity source, double sourceDeltaX, double sourceDeltaZ) {
+        Profile active = profile;
+        KnockbackSettings settings = active.knockback;
+
+        if (settings.onePointSevenKnockback && sameDirection(victim, source)) {
+            return;
+        }
+
+        applyKnockbackVector(victim, -sourceDeltaX, -sourceDeltaZ, settings.horizontal, settings.vertical, settings.horizontalFriction, settings.verticalFriction, settings.verticalLimit, -Double.MAX_VALUE);
+        applyNoDamageTicks(victim, settings.maxNoDamageTicks);
+    }
+
+    public static void applyExtraKnockback(Entity target, EntityHuman attacker, int level) {
+        if (target == null || attacker == null || level <= 0) {
+            return;
+        }
+
+        KnockbackSettings settings = profile.knockback;
+        target.g(-MathHelper.sin(attacker.yaw * 3.1415927F / 180.0F) * (float) level * settings.extraHorizontal, settings.extraVertical, MathHelper.cos(attacker.yaw * 3.1415927F / 180.0F) * (float) level * settings.extraHorizontal);
+    }
+
+    public static void applyAttackerPostHit(EntityHuman attacker) {
+        if (attacker == null) {
+            return;
+        }
+
+        KnockbackSettings settings = profile.knockback;
+        if (settings.slowdown.enabled) {
+            attacker.motX *= settings.slowdown.value;
+            attacker.motZ *= settings.slowdown.value;
+        }
+        if (settings.resetSprint) {
+            attacker.setSprinting(false);
+        }
+    }
+
+    public static void applyProjectileImpact(Entity projectile, Entity hit, Entity owner) {
+        if (!(hit instanceof EntityLiving)) {
+            return;
+        }
+
+        ImpactSettings settings = impactFor(projectile);
+        if (settings == null || !settings.enabled) {
+            return;
+        }
+
+        double x = projectile.motX;
+        double z = projectile.motZ;
+        if (settings instanceof FishingHookImpactSettings) {
+            FishingHookImpactSettings fishing = (FishingHookImpactSettings) settings;
+            if (fishing.classicRods.enabled) {
+                applyKnockbackVector((EntityLiving) hit, x, z, fishing.classicRods.horizontal, fishing.classicRods.vertical, 1.0D, 1.0D, settings.verticalLimit, settings.minVerticalLimit);
+                applyNoDamageTicks((EntityLiving) hit, settings.maxNoDamageTicks);
+                return;
+            }
+            if (fishing.directionBased && owner != null) {
+                x = -MathHelper.sin(owner.yaw * 3.1415927F / 180.0F);
+                z = MathHelper.cos(owner.yaw * 3.1415927F / 180.0F);
+            }
+            if (fishing.fishVelocity.enabled && owner != null) {
+                hit.motX += (owner.locX - hit.locX) * fishing.fishVelocity.multiplier;
+                hit.motY += fishing.fishVelocity.verticalMultiplier;
+                hit.motZ += (owner.locZ - hit.locZ) * fishing.fishVelocity.multiplier;
+                hit.velocityChanged = true;
+            }
+        }
+
+        if (settings.straightKnockback && owner != null) {
+            x = -MathHelper.sin(owner.yaw * 3.1415927F / 180.0F);
+            z = MathHelper.cos(owner.yaw * 3.1415927F / 180.0F);
+        }
+
+        applyKnockbackVector((EntityLiving) hit, x, z, settings.horizontal, settings.vertical, settings.horizontalFriction, settings.verticalFriction, settings.verticalLimit, settings.minVerticalLimit);
+        if (settings instanceof ArrowImpactSettings) {
+            ArrowImpactSettings arrow = (ArrowImpactSettings) settings;
+            if (arrow.extraHorizontal != 0.0D || arrow.extraVertical != 0.0D) {
+                applyKnockbackVector((EntityLiving) hit, x, z, arrow.extraHorizontal, arrow.extraVertical, 1.0D, 1.0D, settings.verticalLimit, settings.minVerticalLimit);
+            }
+        }
+        applyNoDamageTicks((EntityLiving) hit, settings.maxNoDamageTicks);
+    }
+
+    public static void applyExplosionImpact(Entity hit, double x, double y, double z, double vanillaStrength) {
+        if (!(hit instanceof EntityLiving)) {
+            return;
+        }
+
+        ImpactSettings settings = profile.explosionImpact;
+        if (!settings.enabled) {
+            hit.motX += x * vanillaStrength;
+            hit.motY += y * vanillaStrength;
+            hit.motZ += z * vanillaStrength;
+            return;
+        }
+
+        EntityLiving living = (EntityLiving) hit;
+        living.motX /= settings.horizontalFriction;
+        living.motY /= settings.verticalFriction;
+        living.motZ /= settings.horizontalFriction;
+        living.motX += x * settings.horizontal;
+        living.motY += settings.straightKnockback ? y * settings.vertical : settings.vertical;
+        living.motZ += z * settings.horizontal;
+        clampVertical(living, settings.verticalLimit, settings.minVerticalLimit);
+        applyNoDamageTicks(living, settings.maxNoDamageTicks);
+        living.velocityChanged = true;
+    }
