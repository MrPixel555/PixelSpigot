+    private static ImpactSettings impactFor(Entity entity) {
+        Profile active = profile;
+        if (entity instanceof EntityArrow) return active.arrowImpact;
+        if (entity instanceof EntityEnderPearl) return active.enderPearlImpact;
+        if (entity instanceof EntitySnowball) return active.snowballImpact;
+        if (entity instanceof EntityEgg) return active.eggImpact;
+        if (entity instanceof EntityFishingHook) return active.fishingHookImpact;
+        return null;
+    }
+
+    private static ProjectileSettings projectileFor(Entity entity) {
+        Profile active = profile;
+        if (entity instanceof EntityArrow) return active.arrowProjectile;
+        if (entity instanceof EntityEnderPearl) return active.enderPearlProjectile;
+        if (entity instanceof EntitySnowball) return active.snowballProjectile;
+        if (entity instanceof EntityEgg) return active.eggProjectile;
+        if (entity instanceof EntityFishingHook) return active.fishingHookProjectile;
+        if (entity instanceof EntityPotion) return active.splashPotionProjectile;
+        return null;
+    }
