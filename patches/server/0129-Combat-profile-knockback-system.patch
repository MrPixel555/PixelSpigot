+    private static boolean sameDirection(EntityLiving victim, Entity source) {
+        if (!(source instanceof EntityLiving)) {
+            return false;
+        }
+        float diff = Math.abs(MathHelper.g(victim.yaw - source.yaw));
+        return diff < 45.0F;
+    }
+
+    private static void applyKnockbackVector(EntityLiving victim, double x, double z, double horizontal, double vertical, double horizontalFriction, double verticalFriction, double verticalLimit, double minVerticalLimit) {
+        double magnitude = Math.sqrt(x * x + z * z);
+        if (magnitude <= 1.0E-7D) {
+            return;
+        }
+
+        victim.ai = true;
+        victim.motX /= horizontalFriction;
+        victim.motY /= verticalFriction;
+        victim.motZ /= horizontalFriction;
+        victim.motX += x / magnitude * horizontal;
+        victim.motY += vertical;
+        victim.motZ += z / magnitude * horizontal;
+        clampVertical(victim, verticalLimit, minVerticalLimit);
+        victim.velocityChanged = true;
+    }
+
+    private static void clampVertical(EntityLiving living, double max, double min) {
+        if (living.motY > max) {
+            living.motY = max;
+        }
+        if (living.motY < min) {
+            living.motY = min;
+        }
+    }
+
+    private static void applyNoDamageTicks(EntityLiving victim, MaxNoDamageTicks ticks) {
+        if (ticks.enabled) {
+            victim.maxNoDamageTicks = ticks.value;
+        }
+    }
