+        settings.fishVelocity.verticalMultiplier = yaml.getDouble(root + "FISH-VELOCITY.VERTICAL-MULTIPLIER", settings.fishVelocity.verticalMultiplier);
+        settings.classicRods.enabled = yaml.getBoolean(root + "CLASSIC-RODS.ENABLED", settings.classicRods.enabled);
+        settings.classicRods.horizontal = yaml.getDouble(root + "CLASSIC-RODS.HORIZONTAL", settings.classicRods.horizontal);
+        settings.classicRods.vertical = yaml.getDouble(root + "CLASSIC-RODS.VERTICAL", settings.classicRods.vertical);
+    }
